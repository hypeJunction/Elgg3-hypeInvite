{
    "name": "hypejunction/hypeinvite",
    "version": "5.0.0",
    "type": "elgg-plugin",
    "description": "Invite-based user registration for Elgg \u2014 email invitations, invite-only networks, and group invitations.",
    "homepage": "https://github.com/hypeJunction/Elgg3-hypeInvite",
    "keywords": [
        "elgg",
        "plugin",
        "invite",
        "invite only network",
        "invite code"
    ],
    "extra": {
        "installer-name": "hypeinvite",
        "elgg-plugin": {
            "id": "hypeinvite"
        }
    },
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Ismayil Khayredinov",
            "email": "ismayil.khayredinov@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "composer/installers": "^2.0",
        "elgg/elgg": "^5.0"
    },
    "autoload": {
        "psr-0": {
            "": "classes/"
        }
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true
        }
    }
}
