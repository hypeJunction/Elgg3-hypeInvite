{
    "name": "hypejunction/hypeinvite",
    "type": "elgg-plugin",
    "description": "An interface for inviting new users to the site",
    "homepage": "https://github.com/hypeJunction/Elgg3-hypeInvite",
    "keywords": [
        "elgg",
        "plugin",
        "invite",
        "invite only network",
        "invite code"
    ],
    "extra": {
        "installer-name": "hypeinvite"
    },
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Ismayil Khayredinov",
            "email": "ismayil.khayredinov@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.3",
        "composer/installers": "^2.0",
        "elgg/elgg": "~7.0.0",
        "ext-intl": "*"
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true
        }
    },
    "autoload": {
        "psr-0": {
            "": "classes/"
        }
    }
}
