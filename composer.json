{
	"name": "hypejunction/hypeinvite",
	"type": "elgg-plugin",
	"description": "An interface for inviting new users to the site",
	"homepage": "http://hypejunction.com",
	"keywords": [
		"elgg",
		"plugin",
		"invite",
		"invite only network",
		"invite code"
	],
	"extra": {
		"installer-name": "hypeInvite"
	},
	"license": "proprietary",
	"authors": [
		{
			"name": "Ismayil Khayredinov",
			"email": "info@hypejunction.com"
		}
	],
	"require": {
		"php": ">=8.3",
		"composer/installers": "^2.0",
		"elgg/elgg": "~7.0.0",
		"ext-intl": "*"
	},
	"config": {
		"allow-plugins": {
			"composer/installers": true
		}
	},
	"autoload": {
		"psr-0": {
			"": "classes/"
		}
	}
}
